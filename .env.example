# GenSI 环境配置示例文件
# 复制此文件为 .env 并填入实际的配置值

# 应用基本配置
VITE_APP_TITLE=GenSI
VITE_APP_DESC=GenSI 网站管理系统
VITE_BASE_URL=/

# Supabase 数据库配置
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# 腾讯云 COS 对象存储配置
VITE_COS_SECRET_ID=your_cos_secret_id
VITE_COS_SECRET_KEY=your_cos_secret_key
VITE_COS_BUCKET=your_bucket_name
VITE_COS_REGION=your_region

# 服务配置
VITE_SERVICE_BASE_URL=https://api.yoursite.com
VITE_SERVICE_SUCCESS_CODE=200
VITE_SERVICE_LOGOUT_CODES=401
VITE_SERVICE_EXPIRED_TOKEN_CODES=401

# 认证配置
VITE_AUTH_ROUTE_MODE=static
VITE_STATIC_SUPER_ROLE=super

# 路由配置
VITE_ROUTER_HISTORY_MODE=hash
VITE_ROUTE_HOME=home

# 开发配置
VITE_HTTP_PROXY=N
VITE_SOURCE_MAP=N
VITE_PROXY_LOG=N

# 存储前缀
VITE_STORAGE_PREFIX=gensi_

# 自动检测更新
VITE_AUTOMATICALLY_DETECT_UPDATE=Y
