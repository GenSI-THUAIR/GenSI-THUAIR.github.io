# 应用基本配置
VITE_APP_TITLE=GenSI
VITE_APP_DESC=GenSI 网站管理系统
VITE_BASE_URL=/

# Supabase 数据库配置
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# 腾讯云 COS 对象存储配置
VITE_COS_BUCKET=your_bucket_name
VITE_COS_REGION=ap-shanghai

# ⚠️ 安全警告：推荐使用 STS 临时密钥而不是永久密钥
# STS 临时密钥服务 URL（推荐，更安全）
VITE_COS_STS_URL=https://your-sts-service.com/get-temp-credentials

# 永久密钥配置（仅作后备，不推荐在生产环境使用）
# VITE_COS_SECRET_ID=your_cos_secret_id
# VITE_COS_SECRET_KEY=your_cos_secret_key

# 服务配置
VITE_SERVICE_BASE_URL=https://api.yoursite.com
VITE_SERVICE_SUCCESS_CODE=200
VITE_SERVICE_LOGOUT_CODES=401
VITE_SERVICE_EXPIRED_TOKEN_CODES=401

# 认证配置
VITE_AUTH_ROUTE_MODE=static
VITE_STATIC_SUPER_ROLE=super
# 关闭路由鉴权(可选): 设置为 false 或 0 可关闭所有登录/权限拦截
VITE_ENABLE_AUTH=true

# 路由配置
VITE_ROUTER_HISTORY_MODE=hash
VITE_ROUTE_HOME=news-manage

# 开发配置
VITE_HTTP_PROXY=N
VITE_SOURCE_MAP=N
VITE_PROXY_LOG=N

# 存储前缀
VITE_STORAGE_PREFIX=gensi_

# 自动检测更新
VITE_AUTOMATICALLY_DETECT_UPDATE=Y 