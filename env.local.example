# ======================================
# GenSI 项目本地环境变量配置示例
# ======================================
# 
# 使用说明：
# 1. 复制此文件为 .env.local
# 2. 填入你的真实配置信息
# 3. .env.local 不会被提交到 Git，保证安全
#

# ======================================
# COS 配置（二选一）
# ======================================

# 方案1：STS 临时密钥（推荐，更安全）
# 需要先部署 STS 服务，参考 COS_STS_SETUP.md
VITE_COS_STS_URL=https://your-sts-service.com/get-temp-credentials

# 方案2：永久密钥（仅开发环境，生产环境不推荐）
# 在腾讯云 CAM 控制台获取，建议创建子用户并设置最小权限
# VITE_COS_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_COS_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 基础配置
VITE_COS_BUCKET=gensi-1316936694
VITE_COS_REGION=ap-shanghai

# ======================================
# Supabase 配置
# ======================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ======================================
# 其他配置
# ======================================
VITE_APP_TITLE=GenSI
VITE_APP_DESC=GenSI 网站管理系统
VITE_STORAGE_PREFIX=gensi_ 